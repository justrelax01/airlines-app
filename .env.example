APP_NAME="Airlines App"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=airlines
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
# For production use "database" or "redis" to process jobs asynchronously
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
# Session lifetime in minutes (480 = 8 hours)
SESSION_LIFETIME=480

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use "log" for local development (writes emails to storage/logs/laravel.log)
# Use "smtp" and fill in credentials for production
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@airlines.app"
MAIL_FROM_NAME="${APP_NAME}"

# Comma-separated list of allowed CORS origins for the API
# In production set this to your actual frontend domain, e.g. https://yourdomain.com
CORS_ALLOWED_ORIGINS="${APP_URL}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
